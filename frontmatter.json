{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": null,
      "fields": [
        {
          "title": "layout",
          "name": "layout",
          "type": "string",
          "default": "post"
        },
        {
          "title": "title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "published",
          "name": "published",
          "type": "boolean",
          "default": false
        },
        {
          "title": "categories",
          "name": "categories",
          "type": "categories"
        },
        {
          "title": "comment",
          "name": "comment",
          "type": "boolean",
          "default": true
        }
      ]
    }
  ],
  "frontMatter.framework.id": "jekyll",
  "frontMatter.content.publicFolder": "assets",
  "frontMatter.preview.host": "http://localhost:4000",
  "frontMatter.content.pageFolders": [
    {
      "title": "drafts",
      "path": "[[workspace]]/_drafts"
    },
    {
      "title": "posts",
      "path": "[[workspace]]/_posts"
    },
    {
      "path": "[[workspace]]/_posts/articles"
    }
  ],
  "frontMatter.git.enabled": false,
  "frontMatter.website.host": "https://www.rachelgold.ca/",
  "frontMatter.dashboard.openOnStart": true,
  "frontMatter.panel.openOnSupportedFile": true
}